# ============================================================
# PlantDiseaseAI - .gitignore
# ============================================================

# Environment variables — NEVER commit this!
.env

# Python cache
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python

# Virtual environment
venv/
env/
.venv/

# Uploaded images (user data)
uploads/

# Generated audio files
output_audio/

# Trained model files (tracked via Git LFS — see .gitattributes)
model/*.keras
model/*.h5
model/*.pb
# model/*.pth  <-- tracked via Git LFS, NOT ignored
model/*.pt

# IDE / OS files
.vscode/
.idea/
*.DS_Store
Thumbs.db
